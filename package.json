{
  "name": "safertranslate",
  "version": "0.1.0",
  "description": "Chrome translation extension with bilingual display (immersivetranslate.com style)",
  "type": "module",
  "author": "padawansato",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/padawansato/safertranslate.git"
  },
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "tsc --noEmit && vite build",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.40.0",
    "@types/chrome": "^0.0.260",
    "@types/node": "^20.10.0",
    "eslint": "^9.39.2",
    "jsdom": "^27.3.0",
    "msw": "^2.0.0",
    "serve": "^14.2.5",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.50.1",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}

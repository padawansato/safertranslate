{
  "name": "safertranslate",
  "version": "0.1.0",
  "description": "AI-First Self-Driving TDD + Clean Architecture Browser Extension for Immersive Translation",
  "license": "MIT",
  "author": {
    "name": "SaferTranslate Team",
    "email": "team@safertranslate.dev"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/padawansato/safertranslate.git"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "🤖 AI-First Development": "echo 'Claude Code Self-Driving Commands'",
    "claude:auto-tdd": "tsx automation/orchestrator/ClaudeCodeOrchestrator.ts",
    "claude:generate-tests": "tsx automation/orchestrator/TestGenerator.ts",
    "claude:implement": "tsx automation/orchestrator/TDDCycleManager.ts --mode implement",
    "claude:refactor": "tsx automation/orchestrator/TDDCycleManager.ts --mode refactor",
    "claude:bootstrap": "tsx automation/orchestrator/ClaudeCodeOrchestrator.ts --bootstrap",
    "claude:analyze-requirements": "tsx automation/orchestrator/RequirementAnalyzer.ts",
    "claude:continuous-improvement": "tsx automation/monitoring/QualityAnalyzer.ts --continuous",
    
    "🧪 Automated Testing": "echo 'AI-Driven Test Management'",
    "test": "jest --config build/jest.config.ts",
    "test:auto": "tsx automation/auto-fix/TestFailureAnalyzer.ts && npm test",
    "test:generate": "tsx automation/orchestrator/TestGenerator.ts --generate-missing",
    "test:coverage": "jest --coverage && tsx automation/monitoring/CoverageMonitor.ts",
    "test:watch": "jest --watch",
    "test:domain": "jest tests/domain",
    "test:application": "jest tests/application", 
    "test:infrastructure": "jest tests/infrastructure",
    "test:presentation": "jest tests/presentation",
    "test:e2e": "playwright test",
    "test:e2e:auto": "tsx automation/orchestrator/TestRunner.ts --e2e",
    "test:integration": "jest tests/*/integration",
    
    "⚡ Smart Build & Deploy": "echo 'Automated Build Pipeline'",
    "build": "npm run build:chrome && npm run build:safari",
    "build:chrome": "webpack --config build/webpack.chrome.config.ts",
    "build:safari": "webpack --config build/webpack.safari.config.ts && npm run build:safari:xcode",
    "build:safari:xcode": "xcodebuild -project src/presentation/safari-extension/SaferTranslate/SaferTranslate.xcodeproj",
    "build:optimize": "tsx automation/deployment/BuildAutomator.ts --optimize",
    "build:analyze": "webpack-bundle-analyzer dist/chrome/stats.json",
    
    "🔄 Development": "echo 'Traditional Development Commands'",
    "dev": "concurrently \"npm run dev:chrome\" \"npm run dev:safari\"",
    "dev:chrome": "webpack --config build/webpack.chrome.config.ts --watch",
    "dev:safari": "webpack --config build/webpack.safari.config.ts --watch",
    "dev:popup": "webpack-dev-server --config build/webpack.popup.config.ts",
    
    "📊 Quality & Monitoring": "echo 'Code Quality Management'",
    "lint": "eslint src/**/*.ts --fix",
    "lint:check": "eslint src/**/*.ts",
    "type-check": "tsc --noEmit",
    "format": "prettier --write src/**/*.{ts,js,json,css,html}",
    "format:check": "prettier --check src/**/*.{ts,js,json,css,html}",
    "monitor:quality": "tsx automation/monitoring/QualityAnalyzer.ts",
    "monitor:performance": "tsx automation/monitoring/PerformanceMonitor.ts",
    "monitor:security": "tsx automation/monitoring/SecurityScanner.ts",
    
    "🚀 Deployment": "echo 'Release Management'",
    "deploy:auto": "tsx automation/deployment/ReleaseManager.ts --auto",
    "deploy:chrome": "tsx automation/deployment/ReleaseManager.ts --chrome",
    "deploy:safari": "tsx automation/deployment/ReleaseManager.ts --safari",
    "version:bump": "tsx automation/deployment/ReleaseManager.ts --bump-version",
    
    "🛠️ Setup & Maintenance": "echo 'Project Setup'",
    "setup": "npm install && npm run setup:husky && npm run claude:bootstrap",
    "setup:husky": "husky install",
    "clean": "rimraf dist build/tmp node_modules/.cache",
    "clean:install": "npm run clean && npm install",
    "doctor": "tsx automation/monitoring/QualityAnalyzer.ts --doctor"
  },
  "dependencies": {
    "reflect-metadata": "^0.1.13"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.258",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@types/webextension-polyfill": "^0.10.7",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.2",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.2.0",
    "playwright": "^1.41.0",
    "prettier": "^3.1.1",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "webpack": "^5.89.0",
    "webpack-bundle-analyzer": "^4.10.1",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1",
    "webextension-polyfill": "^0.10.0"
  },
  "lint-staged": {
    "src/**/*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{json,css,html}": [
      "prettier --write"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged && npm run test:auto",
      "pre-push": "npm run type-check && npm run test:coverage"
    }
  },
  "keywords": [
    "browser-extension",
    "translation",
    "chrome",
    "safari",
    "clean-architecture",
    "tdd",
    "ai-first",
    "claude-code",
    "typescript",
    "immersive-translate"
  ]
}